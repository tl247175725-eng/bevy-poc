#!/bin/bash
# 每次 push 前强制检查：最多改 2 个 .rs 文件
# 超过 2 个 → 拒绝 push。拆成小 commit 再推。

CHANGED=$(git diff --cached --name-only --diff-filter=M | grep "\.rs$" | wc -l)
NEW=$(git diff --cached --name-only --diff-filter=A | grep "\.rs$" | wc -l)
TOTAL=$((CHANGED + NEW))

if [ "$TOTAL" -gt 2 ]; then
    echo "❌ 一次改了 $TOTAL 个 .rs 文件，最多允许 2 个"
    echo "   请拆成小 commit，每个只改 1-2 个文件"
    echo "   git reset HEAD~1 → 分批 add → 分批 commit"
    exit 1
fi

echo "✅ 文件数检查通过 ($TOTAL 个 .rs)"
exit 0
